{
  "name": "exe-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .vue,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,js,json,css,scss,md}\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.11.0",
    "dplayer": "^1.27.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.10.5",
    "gsap": "^3.13.0",
    "hls.js": "^1.6.15",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lodash-es": "^4.17.22",
    "markdown-it": "^14.1.0",
    "marked": "^17.0.1",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "vue": "^3.5.17",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.1",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.2",
    "terser": "^5.36.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  }
}
